# ===============================
# Server Configuration
# ===============================
PORT=5000
NODE_ENV=development

# ===============================
# Authentication / Security
# ===============================
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ===============================
# GitHub OAuth
# ===============================
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
# Optional: explicit backend base URL (used to build callback URL)
SERVER_URL=http://localhost:5000
# Optional: override callback URL directly for GitHub OAuth app settings
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback
# Optional: OAuth scopes requested during GitHub login (include repo for private repos)
GITHUB_OAUTH_SCOPES=user:email,repo
# Optional: scopes required before fetching owned repositories
GITHUB_REQUIRED_SCOPES=repo

# ===============================
# GitHub Webhooks
# ===============================
# Required for PR integration webhook
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_here

# GitHub personal access token for posting comments to PRs
# Requires: repo scope (full control of private repositories)
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_github_personal_access_token_here

# ===============================
# CORS
# ===============================
CLIENT_URL=http://localhost:5173

# ===============================
# Optionals
# ===============================
# COOKIE_SECRET=your_cookie_secret
# REFRESH_TOKEN_SECRET=your_refresh_secret

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini          # cheapest model with good quality
AI_CACHE_TTL_SECONDS=3600         # cache explanations for 1 hour
REDIS_URL=redis://localhost:6379  # omit to use in-memory cache
REDIS_HOST=localhost              # use redis when app runs inside Docker
REDIS_PORT=6379

DATABASE_URL=postgres://postgres:postgres@localhost:5433/codegraph

# ===============================
# Observability (Sentry)
# ===============================
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
